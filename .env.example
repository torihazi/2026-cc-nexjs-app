# 環境変数テンプレート
#
# このファイルをコピーして .env.local を作り、実際の値を埋める:
#   cp .env.example .env.local
#
# キーの定義元 (単一の信頼できるソース) は src/env.ts。
# 必須の env が欠けているとアプリ起動時に検証が throw して fail-fast する。
# 実際の値 (シークレット) は絶対にコミットしない (.gitignore で .env.* は除外済み)。

# libSQL / Turso のデータベース URL。
# 本番は Turso の libsql:// URL を指定する。
TURSO_DATABASE_URL="file:./local.db"

# Google OAuth (better-auth のソーシャルログインに使用)。
# Google Cloud Console の OAuth 2.0 クライアントから取得する。
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# better-auth のセッション署名用シークレット。ランダムな長い文字列を生成して設定する:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=""

# libSQL/Turso の認証トークン。値は必ず env で与える (config 側では補完しない)。
# 本番 (libsql://) は Turso の実トークンを設定する。
# ローカルの file: DB は本来認証不要だが、drizzle-kit の "turso" dialect が非空トークンを
# 要求するため、ローカルでもダミー値を必ず設定する (空だと db:migrate が [x] authToken で落ちる)。
TURSO_AUTH_TOKEN="local-anon-token"

# better-auth のベース URL。未設定なら実行環境から推定する。
# 例: http://localhost:3000
BETTER_AUTH_URL=""

# Google Books API キー (任意)。匿名クォータ超過 (429) を避けるための本番向け配線。
GOOGLE_BOOKS_API_KEY=""

# ブラウザ側 better-auth クライアントが参照するベース URL。
# NEXT_PUBLIC_* はビルド時にバンドルへ静的置換されるため公開値のみ入れること。
NEXT_PUBLIC_BETTER_AUTH_URL=""

# --- 緊急避難用 --------------------------------------------------------------

# Docker ビルド等で env 検証を一時的にスキップしたいときだけ 1 を設定する。通常は未設定。
# SKIP_ENV_VALIDATION=
