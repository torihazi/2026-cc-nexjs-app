{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "[ -x ./scripts/check.sh ] && ./scripts/check.sh || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.*.local)",
      "Read(.env.development)",
      "Read(.env.development.local)",
      "Read(.env.production)",
      "Read(.env.production.local)",
      "Read(.env.test)",
      "Read(.env.test.local)",
      "Bash(cat .env*)",
      "Bash(head .env*)",
      "Bash(tail .env*)",
      "Bash(less .env*)",
      "Bash(more .env*)",
      "Bash(strings .env*)",
      "Bash(xxd .env*)",
      "Bash(od .env*)",

      "Write(.env)",
      "Write(.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",

      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "Bash(rm -r -f*)",
      "Bash(rm -f -r*)",
      "Bash(sudo rm*)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(chmod -R 777*)",
      "Bash(chmod 777*)",

      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push --mirror*)",
      "Bash(git push --delete*)",
      "Bash(git push origin --delete*)",
      "Bash(git push origin +*)"
    ]
  }
}
